# STM32 / CubeIDE patterns
CRITICAL  HARD_FAULT        HardFault_Handler
CRITICAL  MEM_FAULT         MemManage_Handler
CRITICAL  BUS_FAULT         BusFault_Handler
CRITICAL  USAGE_FAULT       UsageFault_Handler
CRITICAL  STACK_OVERFLOW    stack overflow
HIGH      ASSERT_FAILED     assert_failed
HIGH      ERROR_HANDLER     Error_Handler
WARN      HAL_ERROR         HAL_ERROR
